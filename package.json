{
  "name": "celebrate",
  "version": "1.0.0",
  "main": "index.ts",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'App.tsx'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'App.tsx' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,json}' 'App.tsx'",
    "typecheck": "tsc --noEmit",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug"
  },
  "dependencies": {
    "@react-navigation/native": "7.1.26",
    "@react-navigation/native-stack": "^7.14.11",
    "@tanstack/react-query": "^5.51.11",
    "expo": "^53.0.0",
    "expo-dev-client": "~5.2.4",
    "expo-status-bar": "~2.2.3",
    "nativewind": "4.1.23",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "tailwindcss": "^3.4.19",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@config-plugins/detox": "^11.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.0.0",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "detox": "^20.50.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.14",
    "prettier": "^3.0.0",
    "typescript": "~5.8.0"
  },
  "private": true
}
